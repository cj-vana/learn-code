# Copy to .env to override any Docker Compose default. Real .env stays untracked.

# CLI target (host side). The web app never uses this; it calls relative /api.
LEARN_CODE_API_URL=http://127.0.0.1:8000

# API-owned SQLite on the api-data named volume (four slashes = absolute path).
LEARN_CODE_DATABASE_URL=sqlite:////data/learn-code.sqlite3

# Content tree mounted read-only into api and runner-broker at /srv/content.
LEARN_CODE_CONTENT_ROOT=/srv/content/python

# API -> runner-broker over HTTP (internal compose network, no host port).
RUNNER_BROKER_URL=http://runner-broker:8080

# Build-only image tag runner-broker runs per job (must match the python-runner
# service image tag in docker-compose.yml).
PYTHON_RUNNER_IMAGE=learn-code-python-runner:local

# Sibling-container workspace. MUST be an absolute path: it is bind-mounted
# host:container at the identical path so the HOST daemon can resolve the
# per-run workspace dir when runner-broker launches a runner container.
RUNNER_WORKSPACE_DIR=/tmp/learn-code-runner

# Vite dev-server proxy target for /api (compose service address).
VITE_API_PROXY_TARGET=http://api:8000

# Optional local Ollama code review. Never required; unreachable -> friendly skip.
OLLAMA_ENABLED=auto
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=granite-code:8b
OLLAMA_TIMEOUT_SECONDS=30
